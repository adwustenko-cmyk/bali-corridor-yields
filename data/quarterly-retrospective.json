  "key_findings": [
    {
      "finding": "Corridor-wide gross yield softening of 0.2-0.7pp Q4→Q1",
      "drivers": "1BR off-plan supply (esp. Bukit), Berawa pricing reaching local ceiling, broader supply absorption faster than demand growth",
      "severity": "moderate",
      "implication": "If Q2 2026 shows another 0.3-0.7pp drop, corridor is in structural softening cycle. Re-underwrite all in-flight deals at lower bound."
    },
    {
      "finding": "Pererenan-arbitrage thesis holding",
      "drivers": "Pererenan softened only 0.1pp vs Berawa's 0.5pp — relative position improving",
      "severity": "positive",
      "implication": "Pererenan now closer to par with Berawa on net basis. Reweighting recommendation: Pererenan share of new buys should increase quarter-over-quarter."
    },
    {
      "finding": "Bingin 1BR saturation accelerating",
      "drivers": "0.7pp gross yield drop is largest in dataset. ADR -$20/night peak suggests competitive over-supply.",
      "severity": "warning",
      "implication": "1BR off-plan in Bingin/Pecatu now operates at thin margins. Underwrite at lower bound. Avoid additional 1BR exposure in this corridor."
    },
    {
      "finding": "Nusa Dua remains lowest-variance",
      "drivers": "ITDC-managed environment + family-luxury demand insulates from short-term cycle",
      "severity": "stable",
      "implication": "Nusa Dua continues to behave as the corridor floor. Use as defensive allocation in any portfolio model."
    },
    {
      "finding": "Wellness/Ubud corridor most resilient",
      "drivers": "Longer average stay (5+ nights) reduces ADR-volatility exposure. Repeat-visitor rate buffers occupancy.",
